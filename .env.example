BACKEND_PORT=8080
GATEWAY_PORT=3000
BACKEND_URL=http://localhost:8080
X402_FACILITATOR_URL=https://x402.org/facilitator

# 真实 AI 预测（Premium 层）。留空则 Premium 自动回退到规则模型。
# 兼容 OpenAI / DeepSeek / Claude 等任意 OpenAI 格式接口。
OPENAI_API_KEY=
# 可选：自定义接口地址（DeepSeek 示例：https://api.deepseek.com/v1）
OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：模型名（如 gpt-4o-mini / deepseek-chat）
OPENAI_MODEL=gpt-4o-mini
